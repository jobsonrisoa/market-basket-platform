{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://market-basket-platform/contracts/seller/seller-approved-v1.schema.json",
  "title": "seller.approved.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "version", "occurredAt", "correlationId", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "seller.approved.v1"},
    "version": {"const": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sellerId",
        "name",
        "ownerUserId",
        "approvalStatus",
        "reviewedByUserId",
        "reviewedAt"
      ],
      "properties": {
        "sellerId": {"type": "string", "format": "uuid"},
        "name": {"type": "string", "minLength": 1},
        "ownerUserId": {"type": "string", "format": "uuid"},
        "approvalStatus": {"const": "APPROVED"},
        "reviewedByUserId": {"type": "string", "format": "uuid"},
        "reviewedAt": {"type": "string", "format": "date-time"}
      }
    }
  }
}
