{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://market-basket-platform/contracts/auth/session-login-succeeded-v1.schema.json",
  "title": "auth.session.login_succeeded.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventType", "version", "occurredAt", "correlationId", "payload"],
  "properties": {
    "eventId": {"type": "string", "format": "uuid"},
    "eventType": {"const": "auth.session.login_succeeded.v1"},
    "version": {"const": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["userId", "email"],
      "properties": {
        "userId": {"type": "string", "format": "uuid"},
        "email": {"type": "string", "format": "email"}
      }
    }
  }
}
